# Plantilla de conexión a Supabase (Postgres). Copiar a .env y completar.
# NOTA: el deploy del esquema con `cds deploy` lee las credenciales desde
# .cdsrc-private.json (no desde .env). Este archivo es solo referencia / para
# armar el `cf cups incidents-db -p '{...}'`.
PGHOST=aws-1-us-east-1.pooler.supabase.com
PGPORT=5432
PGDATABASE=postgres
PGUSER=<TU_USER_SUPABASE>
PGPASSWORD=<TU_PASSWORD_SUPABASE>
PGSSLMODE=require
